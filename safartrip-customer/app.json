{
  "expo": {
    "name": "SafarTrip",
    "slug": "safartrip-customer",
    "version": "1.0.0",
    "scheme": "safartrip",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#1F4E79"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "uz.safartrip.customer",
      "buildNumber": "1"
    },
    "android": {
      "package": "uz.safartrip.customer",
      "versionCode": 1,
      "permissions": [
        "INTERNET",
        "ACCESS_NETWORK_STATE",
        "CALL_PHONE"
      ],
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#1F4E79"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      "expo-font",
      [
        "expo-image-picker",
        {
          "photosPermission": "Suratlarni tanlash uchun ruxsat kerak."
        }
      ],
      "@react-native-community/datetimepicker"
    ]
  }
}
