{
  "name": "safar",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "prebuild": "node -e \"try{require('fs').rmSync('.next/standalone',{recursive:true,force:true})}catch(e){}\"",
    "build": "cross-env NODE_OPTIONS=--max-old-space-size=8192 next build --webpack",
    "copy:standalone": "shx cp -r .next/static .next/standalone/.next/static && shx cp -r public .next/standalone/public && shx cp .env .next/standalone/.env && shx cp -r node_modules/@img .next/standalone/node_modules/next/node_modules/@img",
    "sync-sharp-standalone": "node scripts/sync-sharp-standalone.mjs",
    "build:standalone": "next build --webpack && npm run sync-sharp-standalone",
    "start": "next start -p 3000",
    "start:prod": "node .next/standalone/server.js",
    "lint": "eslint .",
    "deploy": "bash scripts/deploy.sh",
    "db:push": "prisma db push",
    "db:migrate": "prisma migrate deploy",
    "db:seed": "tsx scripts/seed-test-data.ts",
    "db:fix-partners": "tsx scripts/fix-missing-partners.ts",
    "db:inspect-homestay": "tsx scripts/inspect-homestay-user.ts",
    "db:approve-pending-homestays": "tsx scripts/approve-pending-homestays.ts",
    "db:inspect-user": "tsx scripts/inspect-user.ts",
    "generate:expo-assets": "node scripts/generate-safartrip-assets.mjs"
  },
  "dependencies": {
    "@hookform/resolvers": "^5.2.2",
    "@prisma/client": "^6.19.2",
    "autoprefixer": "^10.4.27",
    "bcryptjs": "^3.0.3",
    "jose": "^6.2.2",
    "lucide-react": "^1.7.0",
    "next": "16.2.1",
    "postcss": "^8.5.8",
    "react": "19.2.4",
    "react-datepicker": "^9.1.0",
    "react-dom": "19.2.4",
    "react-hook-form": "^7.72.0",
    "sonner": "^2.0.7",
    "swiper": "^12.1.3",
    "tailwindcss": "^4.2.2",
    "xlsx": "^0.18.5",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.2.2",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-datepicker": "^6.2.0",
    "@types/react-dom": "^19",
    "cross-env": "^10.1.0",
    "eslint": "^9",
    "eslint-config-next": "16.2.1",
    "prisma": "^6.19.2",
    "sharp": "^0.33.5",
    "shx": "^0.4.0",
    "tsx": "^4.20.0",
    "typescript": "^5"
  }
}
